# ──────────────────────────────────────────────
# Codebase Companion RAG — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Gemini API ──────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Firebase Admin SDK ──────────────────────
# Download from Firebase Console -> Project Settings -> Service Accounts
# -> Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# ── Rate Limiting (Upstash Redis) ───────────
# Get a free Redis database at https://upstash.com
# Leave as "memory://" for local development (uses in-memory store, resets on restart)
REDIS_URL=memory://
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# ── Server Configuration ────────────────────
ENV=development
PORT=8000
WORKERS=4

# ── CORS Origins ────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── HuggingFace (Optional) ──────────────────
# Set to avoid rate limit warnings when downloading embedding models
HF_TOKEN=your_hf_token_here
