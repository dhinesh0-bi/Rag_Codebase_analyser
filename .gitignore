# ─────────────────────────────────────────────
# ROOT .gitignore — Codebase Companion RAG
# ─────────────────────────────────────────────

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────
venv/
.venv/
env/
ENV/

# ── Environment variables & secrets ──────────
.env
.env.*
!.env.example
firebase-service-account.json
secrets.json

# ── RAG / ML artifacts ────────────────────────
chroma_db/

# ── Test scripts (temp) ───────────────────────
test_stream.py
test_gemini.py
test_gemini_models.py
test_pipeline.py
test_ast.py

# ── IDEs ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS files ──────────────────────────────────
.DS_Store
Thumbs.db

# ── Frontend — node_modules (covered by frontend/.gitignore too) ──
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.*
!frontend/.env.example
